# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report/
/test-results/
/tests/e2e/.auth/
/scripts/supervised-smoke-result.json
/scripts/visual-qa-auth-truth-ui.json
/scripts/stripe-billing-smoke-result.json
/scripts/stripe-subscription-smoke-result.json
/scripts/stripe-subscription-double-credit-smoke-result.json

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example
!.env.staging.example
!.env.example

# vercel
.vercel

