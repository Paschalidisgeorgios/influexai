  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "format:check": "prettier --check .",
    "i18n:check": "tsx scripts/check-translations.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
