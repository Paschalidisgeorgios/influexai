    "agora-rtc-sdk-ng": "^4.24.4",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "gray-matter": "^4.0.3",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.17.0",
    "marked": "^18.0.4",
    "next": "16.2.7",
    "next-intl": "^4.13.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "reading-time": "^1.5.0",
