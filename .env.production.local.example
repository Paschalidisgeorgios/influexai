# Copy to .env.production.local for LIVE launch operator audits only.
# NEVER commit .env.production.local — it contains production secrets.
#
# Used by: npm run launch:production (requires LAUNCH_MODE=live + LIVE_LAUNCH_CONFIRM)
# Production Supabase ref: hszjafdelcydnppyolkm
#
# Fill every non-comment line below before running the production launch operator.
# Empty keys in .env.production.local override .env.local and will block the gate.

# --- Launch gates (set in shell OR here for local operator runs) ---
# LAUNCH_MODE=live
# LIVE_LAUNCH_CONFIRM=I_UNDERSTAND_THIS_GOES_LIVE

# --- Production Supabase (ref hszjafdelcydnppyolkm) ---
NEXT_PUBLIC_SUPABASE_URL=https://hszjafdelcydnppyolkm.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_PRODUCTION_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_PRODUCTION_SUPABASE_SERVICE_ROLE_KEY

# Read-only migration/table audit (one of these required for LIVE-2 DB gate)
DATABASE_URL=postgresql://postgres.hszjafdelcydnppyolkm:YOUR_DB_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
# SUPABASE_DB_PASSWORD=YOUR_PRODUCTION_DB_PASSWORD

# --- Stripe Live (never sk_test_ / pk_test_ here) ---
STRIPE_MODE=live
NEXT_PUBLIC_STRIPE_MODE=live
STRIPE_SECRET_KEY=sk_live_YOUR_STRIPE_SECRET_KEY
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_STRIPE_PUBLISHABLE_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_LIVE_WEBHOOK_SECRET

# Platform subscription Price IDs — Stripe LIVE mode dashboard
NEXT_PUBLIC_STRIPE_INFLUEXAI_STARTER_MONTHLY=price_YOUR_LIVE_STARTER_MONTHLY
NEXT_PUBLIC_STRIPE_INFLUEXAI_STARTER_YEARLY=price_YOUR_LIVE_STARTER_YEARLY
NEXT_PUBLIC_STRIPE_INFLUEXAI_CREATOR_MONTHLY=price_YOUR_LIVE_CREATOR_MONTHLY
NEXT_PUBLIC_STRIPE_INFLUEXAI_CREATOR_YEARLY=price_YOUR_LIVE_CREATOR_YEARLY
NEXT_PUBLIC_STRIPE_INFLUEXAI_PRO_MONTHLY=price_YOUR_LIVE_PRO_MONTHLY
NEXT_PUBLIC_STRIPE_INFLUEXAI_PRO_YEARLY=price_YOUR_LIVE_PRO_YEARLY
NEXT_PUBLIC_STRIPE_INFLUEXAI_BUSINESS_MONTHLY=price_YOUR_LIVE_BUSINESS_MONTHLY
NEXT_PUBLIC_STRIPE_INFLUEXAI_BUSINESS_YEARLY=price_YOUR_LIVE_BUSINESS_YEARLY

# Credit packs — LIVE mode (25 / 70 / 160 / 320 credits)
STRIPE_CREDITS_25=price_YOUR_LIVE_CREDITS_25
STRIPE_CREDITS_70=price_YOUR_LIVE_CREDITS_70
STRIPE_CREDITS_160=price_YOUR_LIVE_CREDITS_160
STRIPE_CREDITS_320=price_YOUR_LIVE_CREDITS_320

# Agency / White Label — LIVE mode
STRIPE_AGENCY_STARTER_MONTHLY=price_YOUR_LIVE_AGENCY_STARTER_MONTHLY
STRIPE_AGENCY_STARTER_YEARLY=price_YOUR_LIVE_AGENCY_STARTER_YEARLY
STRIPE_AGENCY_PRO_MONTHLY=price_YOUR_LIVE_AGENCY_PRO_MONTHLY
STRIPE_AGENCY_PRO_YEARLY=price_YOUR_LIVE_AGENCY_PRO_YEARLY
STRIPE_AGENCY_ENTERPRISE_MONTHLY=price_YOUR_LIVE_AGENCY_ENTERPRISE_MONTHLY
STRIPE_AGENCY_ENTERPRISE_YEARLY=price_YOUR_LIVE_AGENCY_ENTERPRISE_YEARLY

# --- Image provider (required before provider open phase; stays disabled for dry-run) ---
FAL_API_KEY=YOUR_FAL_API_KEY
# FAL_KEY=YOUR_FAL_KEY

# --- Provider safety (must start closed for launch operator Phase 1) ---
PROVIDERS_DISABLED=true
NEXT_PUBLIC_PROVIDERS_DISABLED=true
ALLOW_SAFE_DEV_PROVIDER_SMOKE=false

# --- Production live smoke (max 1 provider run; never log) ---
LAUNCH_QA_PASSWORD=YOUR_LAUNCH_QA_PASSWORD

# --- App URL ---
NEXT_PUBLIC_APP_URL=https://www.influexaicreator.com
