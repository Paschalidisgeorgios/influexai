# Staging environment template — copy to .env.local or .env.staging for non-production QA.
# Do NOT commit real secrets. Do NOT point local dev at production Supabase or Stripe live keys.

# --- Supabase (staging project) ---
# Create a separate Supabase project for staging/local mutating tests.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_STAGING_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...staging_anon_key
# Service role: staging/local only — never use production service role locally.
SUPABASE_SERVICE_ROLE_KEY=eyJ...staging_service_role

# Optional: override production ref detection if your staging ref differs
# PRODUCTION_SUPABASE_PROJECT_REF=hszjafdelcydnppyolkm

# --- Stripe (test mode only) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Use Stripe test Price IDs for staging (not live production price IDs)
STRIPE_CREDITS_50=price_test_xxx
STRIPE_CREDITS_150=price_test_xxx
STRIPE_CREDITS_350=price_test_xxx
STRIPE_CREDITS_800=price_test_xxx

# --- Providers (disable or use sandbox/test keys) ---
# Set PROVIDERS_DISABLED=true to skip provider-key detection in the dev write guard.
PROVIDERS_DISABLED=true
# FAL_API_KEY=fal_test_or_staging_key
# AKOOL_CLIENT_ID=
# AKOOL_CLIENT_SECRET=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# --- Dev write guard overrides (use with extreme caution) ---
# Do NOT set these for normal development. Mutating writes against production-like
# resources require explicit opt-in:
# ALLOW_PRODUCTION_DEV_WRITES=true
# I_UNDERSTAND_PRODUCTION_WRITES=true

# --- Other keys (staging/test only) ---
# ANTHROPIC_API_KEY=
# ELEVENLABS_API_KEY=
# FAL_WEBHOOK_SECRET=
