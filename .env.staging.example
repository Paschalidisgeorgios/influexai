# =============================================================================
# STAGING ENVIRONMENT TEMPLATE
# =============================================================================
# Copy to .env.local (or .env.staging loaded manually) for non-production QA.
#
# STAGING IS NOT PRODUCTION:
#   - Use a dedicated Supabase staging project (separate DB, separate auth users)
#   - Use Stripe TEST mode only (sk_test_ / pk_test_ / price_test_...)
#   - Keep providers disabled until sandbox keys are configured
#   - Never copy production secrets into this file
#
# Do NOT commit real secrets. Do NOT use production Supabase URL or live Stripe keys.
# See docs/environment-safety.md for setup runbook.

# --- Runtime ---
NODE_ENV=development
VERCEL_ENV=development
NEXT_PUBLIC_VERCEL_ENV=development
STRIPE_MODE=test
NEXT_PUBLIC_STRIPE_MODE=test

# --- Supabase (dedicated staging project) ---
# Create a new Supabase project for staging — do not reuse the production project.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_STAGING_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Optional: override production ref detection if your guard config differs
# PRODUCTION_SUPABASE_PROJECT_REF=your_production_ref_for_detection_only

# --- Stripe (test mode ONLY) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Subscription price IDs — create in Stripe TEST dashboard, not production
NEXT_PUBLIC_STRIPE_INFLUEXAI_STARTER_MONTHLY=price_test_xxx
NEXT_PUBLIC_STRIPE_INFLUEXAI_STARTER_YEARLY=price_test_xxx
NEXT_PUBLIC_STRIPE_INFLUEXAI_CREATOR_MONTHLY=price_test_xxx
NEXT_PUBLIC_STRIPE_INFLUEXAI_CREATOR_YEARLY=price_test_xxx
NEXT_PUBLIC_STRIPE_INFLUEXAI_PRO_MONTHLY=price_test_xxx
NEXT_PUBLIC_STRIPE_INFLUEXAI_PRO_YEARLY=price_test_xxx
NEXT_PUBLIC_STRIPE_INFLUEXAI_BUSINESS_MONTHLY=price_test_xxx
NEXT_PUBLIC_STRIPE_INFLUEXAI_BUSINESS_YEARLY=price_test_xxx

# Credit pack price IDs (test mode)
# Small pack = 25 credits @ €5 — prefer STRIPE_CREDITS_25; STRIPE_CREDITS_50 is legacy alias
STRIPE_CREDITS_25=price_test_xxx
STRIPE_CREDITS_50=price_test_xxx
STRIPE_CREDITS_150=price_test_xxx
STRIPE_CREDITS_350=price_test_xxx
STRIPE_CREDITS_800=price_test_xxx

NEXT_PUBLIC_STRIPE_PRICE_SMALL=price_test_xxx
NEXT_PUBLIC_STRIPE_PRICE_MEDIUM=price_test_xxx
NEXT_PUBLIC_STRIPE_PRICE_LARGE=price_test_xxx
NEXT_PUBLIC_STRIPE_PRICE_XL=price_test_xxx

# --- Providers (disabled by default — enable only after staging DB is ready) ---
PROVIDERS_DISABLED=true
# FAL_API_KEY=fal_staging_or_sandbox_key
# FAL_WEBHOOK_SECRET=staging_webhook_secret
# AKOOL_CLIENT_ID=
# AKOOL_CLIENT_SECRET=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Staging QA (local .env.local only — not for production)
# TEST_USER_EMAIL=test@influexai.test
# TEST_USER_PASSWORD=TestPassword123!
# ADMIN_EMAIL_ALLOWLIST=test@influexai.test
# NEXT_PUBLIC_ADMIN_EMAIL_ALLOWLIST=test@influexai.test
# Run: node scripts/ensure-staging-qa-user.mjs

# --- Other keys (staging/test only) ---
# ANTHROPIC_API_KEY=
# ELEVENLABS_API_KEY=

# --- Dev write guard overrides (extreme caution — not for normal staging QA) ---
# ALLOW_PRODUCTION_DEV_WRITES=true
# I_UNDERSTAND_PRODUCTION_WRITES=true
