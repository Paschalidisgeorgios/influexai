# Copy to .env.local and fill in values. Do not commit secrets.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# fal.ai (Avatar Studio, Live Portrait, image/video tools)
FAL_API_KEY=
# FAL_KEY=

# App URL (optional, for redirects)
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe (server)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Platform subscription Price IDs (public — Agency Starter / Pro / Business / Agency Pro)
NEXT_PUBLIC_STRIPE_AGENCY_STARTER_MONTHLY=price_xxx
NEXT_PUBLIC_STRIPE_AGENCY_STARTER_YEARLY=price_xxx
NEXT_PUBLIC_STRIPE_PRO_MONTHLY=price_xxx
NEXT_PUBLIC_STRIPE_PRO_YEARLY=price_xxx
NEXT_PUBLIC_STRIPE_BUSINESS_MONTHLY=price_xxx
NEXT_PUBLIC_STRIPE_BUSINESS_YEARLY=price_xxx
NEXT_PUBLIC_STRIPE_AGENCY_PRO_MONTHLY=price_xxx
NEXT_PUBLIC_STRIPE_AGENCY_PRO_YEARLY=price_xxx

# Pay-as-you-go credit packs (server — one-time payment)
STRIPE_CREDITS_50=price_xxx
STRIPE_CREDITS_150=price_xxx
STRIPE_CREDITS_350=price_xxx
STRIPE_CREDITS_800=price_xxx

# White-label agency checkout (server — separate from platform pricing above)
# STRIPE_AGENCY_STARTER_MONTHLY=price_xxx
# STRIPE_AGENCY_PRO_MONTHLY=price_xxx
# STRIPE_AGENCY_ENTERPRISE_MONTHLY=price_xxx

# RunPod — deprecated (Avatar Studio uses fal.ai)
# RUNPOD_API_KEY=
# RUNPOD_ENDPOINT_ID=
# RUNPOD_WEBHOOK_SECRET=
