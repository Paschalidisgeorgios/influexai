# Copy to .env.local and fill in values. Do not commit secrets.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# fal.ai (Avatar Studio, Live Portrait, image/video tools)
FAL_API_KEY=
# FAL_KEY=

# App URL (optional, for redirects)
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe Credit Packs (server — in Stripe Dashboard anlegen)
STRIPE_CREDITS_100=price_xxx
STRIPE_CREDITS_300=price_xxx
STRIPE_CREDITS_700=price_xxx
STRIPE_CREDITS_1500=price_xxx

# Optional public aliases (falls Client direkt Price IDs braucht)
# NEXT_PUBLIC_STRIPE_PRICE_PACK_50=price_xxx
# NEXT_PUBLIC_STRIPE_PRICE_PACK_150=price_xxx
# NEXT_PUBLIC_STRIPE_PRICE_PACK_500=price_xxx

# RunPod — deprecated (Avatar Studio uses fal.ai)
# RUNPOD_API_KEY=
# RUNPOD_ENDPOINT_ID=
# RUNPOD_WEBHOOK_SECRET=
