# Copy to .env.local and fill in values. Do not commit secrets.
# Full production checklist: see `.env.example` in the repo root.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# fal.ai (Avatar Studio, Live Portrait, image/video tools)
FAL_API_KEY=
# FAL_KEY=
# Shared secret for /api/lora/webhook (appended as ?secret= on training webhook URL)
FAL_WEBHOOK_SECRET=

# Anthropic (KI Agent, text tools, prompt enhancement)
ANTHROPIC_API_KEY=

# ElevenLabs (TTS / Stimme)
ELEVENLABS_API_KEY=

# Akool (Live Creator, UGC, Face Swap, Live Avatar)
AKOOL_CLIENT_ID=
AKOOL_CLIENT_SECRET=
# Legacy alias (optional): AKOOL_API_KEY=
# AKOOL_DEFAULT_AVATAR_ID=

# App URL (required in production / Vercel)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe (server)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Platform subscription Price IDs (public)
NEXT_PUBLIC_STRIPE_INFLUEXAI_STARTER_MONTHLY=price_1TdvFA14wsQifjWW7JOzXLbu
NEXT_PUBLIC_STRIPE_INFLUEXAI_STARTER_YEARLY=price_1TekKJ14wsQifjWWzemuUhX0
NEXT_PUBLIC_STRIPE_INFLUEXAI_CREATOR_MONTHLY=price_1TekLZ14wsQifjWWBMqPOkxu
NEXT_PUBLIC_STRIPE_INFLUEXAI_CREATOR_YEARLY=price_1TekLy14wsQifjWW4X9cfWtG
NEXT_PUBLIC_STRIPE_INFLUEXAI_PRO_MONTHLY=price_1TekMP14wsQifjWW02TaqO4j
NEXT_PUBLIC_STRIPE_INFLUEXAI_PRO_YEARLY=price_1TekMg14wsQifjWWPIrit0ZS
NEXT_PUBLIC_STRIPE_INFLUEXAI_BUSINESS_MONTHLY=price_1TekN214wsQifjWWyZJNlLDX
NEXT_PUBLIC_STRIPE_INFLUEXAI_BUSINESS_YEARLY=price_1TekNZ14wsQifjWWMZqVMzq8

# Pay-as-you-go credit packs (server — one-time payment)
# Small 25 · Medium 70 · Large 160 · XL 320 credits (incl. bonus where applicable)
STRIPE_CREDITS_50=price_xxx
STRIPE_CREDITS_150=price_xxx
STRIPE_CREDITS_350=price_xxx
STRIPE_CREDITS_800=price_xxx

# Pay-as-you-go credit packs (public — optional client reference / Express Checkout)
NEXT_PUBLIC_STRIPE_PRICE_SMALL=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_MEDIUM=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_LARGE=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_XL=price_xxx

