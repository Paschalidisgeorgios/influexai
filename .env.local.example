# Copy to .env.local and fill in values. Do not commit secrets.
#
# =============================================================================
# SAFE LOCAL DEVELOPMENT — READ FIRST
# =============================================================================
# Prefer copying from .env.staging.example for mutating local QA.
# See docs/environment-safety.md for the full runbook.
#
# DO NOT use in local .env.local:
#   - Production Supabase project ref / URL
#   - sk_live_ / pk_live_ Stripe keys
#   - Production Stripe Price IDs
#   - Production provider keys without isolation
#
# If production-like signals are detected, the Dev Write Guard blocks mutating
# API routes (403 DEV_WRITE_GUARD_BLOCKED). That is a safety net only — NOT
# a substitute for a dedicated staging Supabase project and Stripe test mode.
#
# Recommended: copy .env.staging.example → .env.local and use staging credentials.

# --- Runtime (local safe defaults) ---
NODE_ENV=development
VERCEL_ENV=development
STRIPE_MODE=test

# --- Supabase (staging or local project — NOT production) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_LOCAL_OR_STAGING_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# Service role: staging/local ONLY — triggers dev write guard if combined with prod-like signals
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# --- Stripe (test mode only — never sk_live_ / pk_live_ locally) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Platform subscription Price IDs — use Stripe TEST mode price IDs from your test dashboard
NEXT_PUBLIC_STRIPE_INFLUEXAI_STARTER_MONTHLY=price_test_xxx
NEXT_PUBLIC_STRIPE_INFLUEXAI_STARTER_YEARLY=price_test_xxx
NEXT_PUBLIC_STRIPE_INFLUEXAI_CREATOR_MONTHLY=price_test_xxx
NEXT_PUBLIC_STRIPE_INFLUEXAI_CREATOR_YEARLY=price_test_xxx
NEXT_PUBLIC_STRIPE_INFLUEXAI_PRO_MONTHLY=price_test_xxx
NEXT_PUBLIC_STRIPE_INFLUEXAI_PRO_YEARLY=price_test_xxx
NEXT_PUBLIC_STRIPE_INFLUEXAI_BUSINESS_MONTHLY=price_test_xxx
NEXT_PUBLIC_STRIPE_INFLUEXAI_BUSINESS_YEARLY=price_test_xxx

# Pay-as-you-go credit packs (server — one-time payment, test mode)
STRIPE_CREDITS_50=price_test_xxx
STRIPE_CREDITS_150=price_test_xxx
STRIPE_CREDITS_350=price_test_xxx
STRIPE_CREDITS_800=price_test_xxx

# Pay-as-you-go credit packs (public — optional client reference)
NEXT_PUBLIC_STRIPE_PRICE_SMALL=price_test_xxx
NEXT_PUBLIC_STRIPE_PRICE_MEDIUM=price_test_xxx
NEXT_PUBLIC_STRIPE_PRICE_LARGE=price_test_xxx
NEXT_PUBLIC_STRIPE_PRICE_XL=price_test_xxx

# White-label agency checkout (server — test mode price IDs)
# STRIPE_AGENCY_STARTER_MONTHLY=price_test_xxx
# STRIPE_AGENCY_PRO_MONTHLY=price_test_xxx
# STRIPE_AGENCY_ENTERPRISE_MONTHLY=price_test_xxx

# --- Providers (disabled by default for safe local dev) ---
PROVIDERS_DISABLED=true
# Enable only with sandbox/test credentials on an isolated staging DB:
# FAL_API_KEY=
# FAL_KEY=
# FAL_WEBHOOK_SECRET=
# AKOOL_CLIENT_ID=
# AKOOL_CLIENT_SECRET=

# --- Other API keys (staging/test only) ---
# ANTHROPIC_API_KEY=
# ELEVENLABS_API_KEY=

# --- App URL ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Dev write guard overrides (DANGER — do NOT enable for normal development) ---
# Both variables required to bypass the guard in non-production runtimes:
# ALLOW_PRODUCTION_DEV_WRITES=true
# I_UNDERSTAND_PRODUCTION_WRITES=true

# --- Social OAuth (Canvas Share — staging/test apps only) ---
# TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=
# INSTAGRAM_APP_ID=
# INSTAGRAM_APP_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# YOUTUBE_API_KEY=

# --- Monitoring ---
# NEXT_PUBLIC_SENTRY_DSN=

# --- Deprecated ---
# RUNPOD_API_KEY=  (Avatar Studio uses fal.ai)
